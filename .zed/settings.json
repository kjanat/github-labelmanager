{
	"wrap_guides": [120],
	"formatter": [{
		"external": {
			"command": "dprint",
			"arguments": ["fmt", "--stdin", "{buffer_path}"]
		}
	}],
	"languages": {
		"JavaScript": { "language_servers": ["deno"] },
		"TypeScript": { "language_servers": ["deno"] },
		"TSX": { "language_servers": ["deno"] }
	},
	"lsp": {
		"deno": {
			"settings": { "deno": { "enable": true } }
		},
		"json-language-server": {
			"settings": {
				"json": {
					"schemas": [{
						"fileMatch": ["deno.json", "deno.jsonc"],
						"url": "https://raw.githubusercontent.com/denoland/deno/refs/heads/main/cli/schemas/config-file.v1.json"
					}, {
						"fileMatch": ["package.json"],
						"url": "https://www.schemastore.org/package"
					}]
				}
			}
		}
	}
}
